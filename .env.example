# === LLM Default ===
LLM_DEFAULT_PROVIDER=deepseek
LLM_DEFAULT_TEMPERATURE=0.7
LLM_DEFAULT_MAX_TOKENS=4096
LLM_DEFAULT_TIMEOUT=60000
LLM_DEFAULT_MAX_RETRIES=3

# === LLM Test Endpoint ===
LLM_TEST_ENDPOINT_ENABLED=false

# === OpenAI ===
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# === DeepSeek ===
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# === Qwen ===
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_DEFAULT_MODEL=qwen-plus

# ========== Auth / User ==========
JWT_ACCESS_SECRET=please-change-this-access-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=2h
JWT_REFRESH_SECRET=please-change-this-refresh-secret-min-32-chars
JWT_REFRESH_EXPIRES_IN=30d

SMS_PROVIDER=mock
SMS_ACCESS_KEY=
SMS_ACCESS_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=

VERIFY_CODE_EXPIRES_MIN=5
VERIFY_CODE_MAX_ATTEMPT=5
VERIFY_CODE_SEND_INTERVAL_SEC=60

LOGIN_MAX_FAIL=5
LOGIN_LOCK_MIN=30

# 微信支付（V3）
WECHAT_PAY_APPID=
WECHAT_PAY_MCHID=
WECHAT_PAY_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY_PATH=./certs/wechat/apiclient_key.pem
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_NOTIFY_URL=https://your-domain.com/api/payment/notify/wechat

# 支付宝
ALIPAY_APPID=
ALIPAY_PRIVATE_KEY_PATH=./certs/alipay/app_private_key.pem
ALIPAY_PUBLIC_KEY_PATH=./certs/alipay/alipay_public_key.pem
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_NOTIFY_URL=https://your-domain.com/api/payment/notify/alipay
ALIPAY_RETURN_URL=https://your-domain.com/payment/result

# 业务配置
ORDER_EXPIRE_MINUTES=30
PAYMENT_SANDBOX=true

# 注册赠送配额
REGISTER_GIFT_PAPER_GENERATION=1
REGISTER_GIFT_POLISH=2
REGISTER_GIFT_EXPORT=1
